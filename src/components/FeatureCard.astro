---
import { Icon } from "astro-icon/components";
export interface Props {
    name: string;
    title: string;
    description?: string;
}
const { name, title, description } = Astro.props as Props;
---

<div class="flex flex-col lg:w-[30%] lg:grow-0 lg:shrink-0 gap-3">
    <Icon
        name={name}
        class="w-22 h-22 bg-secondary rounded-full p-3 self-center text-white"
    />
    <h2 class="text-xl font-semibold text-center">{title}</h2>
    {description ? (
        <p class="hyphens-auto">{description}</p>
    ) : (
        <p class="hyphens-auto"><slot /></p>
    )}
</div>
