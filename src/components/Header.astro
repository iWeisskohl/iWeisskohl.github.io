---
import HeaderLink from "./HeaderLink.astro";
---

<header>
	<nav class="flex flex-col md:flex-row items-stretch border-b border-sub">
		<div class="flex grow min-h-20 md:h-20">
			<h2 class="text-3xl shrink-0 pl-8 flex items-center font-thin">
				<a href="/"
					>DR. <span class="text-brand"></span>LING <b
						class="text-secondary">HUANG</b
					></a
				>
			</h2>
			<div class="grow"></div>
			<label
				for="header-button-toggle"
				class="md:hidden cursor-pointer px-4 flex items-center"
			>
				<div>
					<div class="w-6 h-0.5 bg-gray-800 mb-1"></div>
					<div class="w-6 h-0.5 bg-gray-800 mb-1"></div>
					<div class="w-6 h-0.5 bg-gray-800"></div>
				</div>
			</label>
		</div>
		<div class="group">
			<input class="collapse hidden" type="checkbox" id="header-button-toggle" />
			<div
				class="flex flex-col md:flex-row h-0 md:h-auto overflow-hidden group-has-checked:h-auto">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/research">Research</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
				<HeaderLink href="/publications">Publications</HeaderLink>
				<HeaderLink href="/contact">Contact</HeaderLink>
			</div>
		</div>
	</nav>
</header>
