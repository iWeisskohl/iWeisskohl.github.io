---
import type { HTMLAttributes } from 'astro/types'
export interface Props extends HTMLAttributes<'a'> {
    inline?: boolean;
}

const { inline, class: className } = Astro.props;

const linkClass = inline ? '' : 'block p-2 rounded-md hover:bg-secondary px-6';

---

<a class={`${linkClass} transition-colors duration-300 ${className ?? ''}`} 
    {...Astro.props}>
    <slot />
</a>
