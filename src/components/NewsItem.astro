---
export interface Props {
    date: Date;
    title: string;
    url: string;
}

const { date, title, url } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',  // "mmm" -> "Feb"
  year: 'numeric', // "YYYY" -> "2026"
}).format(date);
---

<div class="flex p-0.5">
    <div class="font-semibold mr-2 shrink-0">{formattedDate}:</div>
    <a href={url}>{title}</a>
</div>
