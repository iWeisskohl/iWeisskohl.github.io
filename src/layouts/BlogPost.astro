---
import BaseLayout from "./BaseLayout.astro";
import Link from "../components/Link.astro";

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<BaseLayout>
	<main>
		<article class="flex flex-col items-center mt-10">
			<div class="prose">
				<div class="title">
					<h1>{title}</h1>
					<slot />
				</div>
			</div>
		</article>
	</main>
</BaseLayout>
