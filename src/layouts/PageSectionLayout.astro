---
export interface Props {
	title?: string;
	class?: string;
}

const { title, class: className } = Astro.props;
---

<div
	class=`lg:px-layout-lg md:px-layout-md sm:px-layout-sm px-layout flex flex-col gap-4 my-10 ${className}`
>
	{
		title ? (
			<h2 class="text-2xl font-medium section-header self-start">
				{title}
			</h2>
		) : null
	}
	<slot />
</div>
