---
export interface Props {
	title?: string;
	class?: string;
}

const { title, class: className } = Astro.props;
---

<div class=`px-layout flex flex-col gap-4 my-10 ${className}`>
	{title ? <h2 class="text-2xl font-medium text-brand section-header self-start">{title}</h2> : null}
	<div class="flex gap-4">
		<slot />
	</div>
</div>
